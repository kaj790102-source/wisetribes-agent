# ═══════════════════════════════════════════════════════
#  WiseTribes AI Marketing Team — Environment Config
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git
# ═══════════════════════════════════════════════════════

# ── Domain (THE ONLY LINE YOU CHANGE TO GO LIVE) ───────
# Testing:    wisetribes.online
# Production: wisetribes.in
SITE_URL=wisetribes.online

# ── AI Provider ───────────────────────────────────────
# Choose: anthropic (Claude) or groq (Llama - FREE)
# If Groq key is set but no Anthropic key, Groq is used automatically
AI_PROVIDER=anthropic

# Anthropic (Claude Sonnet 4 - paid but more capable)
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Groq (Llama 3.1 70B - FREE, no credit card needed!)
# Get from: console.groq.com → API Keys → Create Key
# Free tier: 30 requests/min, 14,400/day
# Models: llama-3.1-70b (recommended), llama-3.1-8b, mixtral-8x7b
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-70b

# ── Tavily (FREE — no credit card needed) ──────────────
# 1. Go to: https://app.tavily.com/sign-up
# 2. Sign up with email (no card needed)
# 3. Copy your key from dashboard (starts with tvly-)
# Free tier: 1,000 searches/month — we use ~20/month
TAVILY_API_KEY=tvly-your-key-here

# ── HeyGen (you already have this) ─────────────────────
HEYGEN_API_KEY=your-heygen-key-here
# Get avatar ID after creating your avatar in HeyGen studio
HEYGEN_AVATAR_ID=your-avatar-id-after-creation

# ── Razorpay ───────────────────────────────────────────
# Share this once website design is final
# Create subscription link: razorpay.com → Payment Links → Subscription
RAZORPAY_PAYMENT_LINK=rzp.io/rzp/PASTE_FINAL_LINK_HERE

# ── Meta (WhatsApp + Ads) ──────────────────────────────
# Get from: developers.facebook.com → your app
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-number-id
META_ACCESS_TOKEN=your-meta-token
META_AD_ACCOUNT_ID=act_your-account-id
META_PAGE_ID=your-page-id
INSTAGRAM_ACCOUNT_ID=your-instagram-account-id

# ── Kajol's WhatsApp (receives weekly digest) ──────────
KAJOL_WHATSAPP=918793015698

# ── Email digest ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@wisetribes.in
# Use Gmail App Password (not your login password)
# Generate at: myaccount.google.com/apppasswords
SMTP_PASS=your-gmail-app-password
DIGEST_TO=info@wisetribes.in

# ── Dashboard ──────────────────────────────────────────
PORT=3000
# Change this to any random string — this is your login password
DASHBOARD_SECRET=wisetribes2025secret
